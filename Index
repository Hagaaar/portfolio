<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Portfolio Planning</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0D0C0A;
  --surface: #131210;
  --surface2: #191715;
  --sep: #1E1C19;
  --sep2: #282420;
  --text: #EDE6DC;
  --text2: #9A9088;
  --text3: #564E46;

  --orange: #E87830;
  --orange-bg: #1C1208;
  --orange-t: #F09A6A;

  --blue: #4892D8;
  --blue-bg: #0A1320;
  --blue-t: #7AB4EE;

  --green: #2CAE68;
  --green-bg: #071510;
  --green-t: #58C888;

  --amber: #CC8A28;
  --amber-bg: #181208;
  --amber-t: #DCA850;

  --setup: #6878A0;
  --setup-bg: #0C1018;
  --setup-t: #8EAACC;

  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bot: env(safe-area-inset-bottom, 0px);
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 14px; line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ═══ HEADER ═══ */
#header {
  position: sticky; top: 0; z-index: 200;
  background: var(--bg);
  padding-top: var(--safe-top);
  border-bottom: 1px solid var(--sep);
}
.hdr-top {
  display: flex; align-items: center; justify-content: space-between;
  padding: 11px 14px 7px;
}
.hdr-title {
  font-size: 15px; font-weight: 700; letter-spacing: .06em;
  color: var(--orange);
}
.hdr-sync { display: flex; align-items: center; gap: 6px; }
.sync-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--sep2); flex-shrink: 0; transition: background .4s;
}
.sync-dot.ok      { background: var(--green); }
.sync-dot.syncing { background: var(--amber); animation: pulse .8s infinite; }
.sync-dot.offline { background: #D05050; }
.sync-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text3); letter-spacing: .04em; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }

.hdr-tabs {
  display: flex; width: 100%;
  border-bottom: 1px solid var(--sep);
  padding: 0 8px;
}
.hdr-tab {
  flex: 1; text-align: center;
  padding: 8px 6px; cursor: pointer;
  font-size: 11px; font-weight: 600; letter-spacing: .09em; text-transform: uppercase;
  color: var(--text3); border: none; background: none;
  border-bottom: 2px solid transparent; margin-bottom: -1px;
  transition: color .15s, border-color .15s;
  -webkit-appearance: none;
}
.hdr-tab.tab-planning.active { color: var(--orange-t); border-bottom-color: var(--orange); }
.hdr-tab.tab-volumes.active  { color: var(--blue-t);   border-bottom-color: var(--blue);   }

.hdr-progress {
  padding: 8px 14px 10px;
  display: flex; flex-direction: column; gap: 6px;
}
.hdr-prog-row { display: flex; align-items: center; gap: 8px; }
.hdr-prog-lbl {
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  color: var(--text3); letter-spacing: .07em; text-transform: uppercase;
  width: 46px; flex-shrink: 0; font-weight: 500;
}
.hdr-prog-bar {
  flex: 1; height: 6px; background: var(--sep2);
  border-radius: 3px; overflow: hidden; min-width: 0;
}
.hdr-prog-fill {
  height: 100%; background: var(--green); border-radius: 3px;
  transition: width .4s ease;
}
.hdr-prog-fill-pages { background: var(--blue); }
.hdr-prog-label {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  color: var(--text2); white-space: nowrap;
  width: 68px; text-align: right; font-weight: 400; flex-shrink: 0;
}

/* ═══ TABS ═══ */
.tab-page { display: none; }
.tab-page.active { display: block; }

/* ═══ PLANNING ═══ */
#page-planning { padding-bottom: 60px; }

/* Congés — inline, minimal */
.conges-row {
  padding: 6px 14px 6px 16px;
  display: flex; align-items: center; gap: 8px;
  border-bottom: 1px solid var(--sep);
  opacity: .35;
}
.conges-row .ci { font-size: 12px; }
.conges-row .cl {
  font-family: 'JetBrains Mono', monospace; font-size: 8px;
  color: var(--text3); letter-spacing: .09em; text-transform: uppercase;
}
.conges-row .cd { font-size: 11px; color: var(--text3); margin-left: 4px; }

/* Week row — flat, no border-box */
.wk {
  border-left: 2px solid var(--sep2);
  border-bottom: 1px solid var(--sep);
  background: var(--surface);
  overflow: hidden;
}
.wk.reformat  { border-left-color: var(--orange); }
.wk.nouveau   { border-left-color: var(--blue);   }
.wk.setup     { border-left-color: var(--setup);  }
.wk.finitions { border-left-color: var(--amber);  }

.wk.current { background: var(--surface2); }

.wk.done-all {
  background: var(--green);
  border-left-color: var(--green);
  opacity: 1;
}
.wk.done-all .wk-title    { color: rgba(0,0,0,.85) !important; }
.wk.done-all .wk-sub      { color: rgba(0,0,0,.6); }
.wk.done-all .wk-prog-bar { background: rgba(0,0,0,.18); }
.wk.done-all .wk-prog-fill { background: rgba(0,0,0,.3) !important; width: 100% !important; }
.wk.done-all .wk-prog-pct  { color: rgba(0,0,0,.55); }
.wk.done-all .chev         { color: rgba(0,0,0,.45); }
.wk.done-all .badge        { background: rgba(0,0,0,.18); color: rgba(0,0,0,.7); }

/* Week header */
.wk-head {
  padding: 9px 14px; cursor: pointer; user-select: none;
  display: flex; align-items: flex-start; gap: 10px; min-height: 44px;
}
.wk-head:active { background: var(--surface2); }
.wk-left { flex: 1; min-width: 0; }

.wk-badges { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 4px; align-items: center; }

.badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8px; font-weight: 600; letter-spacing: .07em; text-transform: uppercase;
  padding: 1px 5px; border-radius: 2px;
  line-height: 1.6; white-space: nowrap;
}
.b-setup    { background: var(--setup-bg);  color: var(--setup-t);  }
.b-reformat { background: var(--orange-bg); color: var(--orange-t); }
.b-nouveau  { background: var(--blue-bg);   color: var(--blue-t);   }
.b-finitions{ background: var(--amber-bg);  color: var(--amber-t);  }
.b-vol1     { background: var(--orange-bg); color: var(--orange-t); }
.b-vol2     { background: var(--blue-bg);   color: var(--blue-t);   }
.b-vol3     { background: var(--green-bg);  color: var(--green-t);  }
.b-week     { background: transparent;      color: var(--text3);    }

.wk-title { font-size: 22px; font-weight: 700; line-height: 1.25; margin-bottom: 3px; }
.wk.reformat  .wk-title { color: var(--orange-t); }
.wk.nouveau   .wk-title { color: var(--blue-t);   }
.wk.setup     .wk-title { color: var(--setup-t);  }
.wk.finitions .wk-title { color: var(--amber-t);  }

.wk-sub { font-size: 11px; color: var(--text3); line-height: 1.4; }

.wk-right {
  flex-shrink: 0; display: flex; flex-direction: column;
  align-items: flex-end; gap: 4px; padding-top: 1px;
}
.wk-pages { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text3); }
.wk-prog-wrap { display: flex; align-items: center; gap: 5px; }
.wk-prog-bar { width: 44px; height: 3px; background: var(--sep2); border-radius: 2px; overflow: hidden; }
.wk-prog-fill { height: 100%; border-radius: 2px; transition: width .3s; background: var(--orange); }
.wk.nouveau   .wk-prog-fill { background: var(--blue);  }
.wk.setup     .wk-prog-fill { background: var(--setup); }
.wk.finitions .wk-prog-fill { background: var(--amber); }
.wk-prog-pct { font-family: 'JetBrains Mono', monospace; font-size: 8px; color: var(--text3); width: 24px; text-align: right; }
.chev { font-size: 9px; color: var(--text3); transition: transform .2s; margin-top: 3px; }
.wk.open .chev { transform: rotate(180deg); }

/* Tasks panel */
.wk-tasks { display: none; border-top: 1px solid var(--sep); }
.wk.open .wk-tasks { display: block; }

.tasks-header {
  padding: 5px 14px;
  font-family: 'JetBrains Mono', monospace; font-size: 8px;
  color: var(--text3); letter-spacing: .1em; text-transform: uppercase;
  border-bottom: 1px solid var(--sep);
}
.task {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 8px 14px;
  border-bottom: 1px solid var(--sep);
  min-height: 40px;
  cursor: pointer;
}
.task:last-of-type { border-bottom: none; }
.task.done { background: var(--green); }
.task.done .task-txt { color: rgba(0,0,0,.82); font-weight: 500; }
.task.done .task-pages-badge { color: rgba(0,0,0,.55); }
.task.done .task-cb:checked { background: rgba(0,0,0,.22); border-color: rgba(0,0,0,.15); }
.task.done .task-cb:checked::after { color: #fff; }

.task-cb {
  width: 16px; height: 16px; flex-shrink: 0;
  border: 1px solid var(--sep2);
  border-radius: 3px; margin-top: 1px;
  cursor: pointer; -webkit-appearance: none; appearance: none;
  background: var(--surface); position: relative; transition: all .15s;
}
.task-cb:checked { background: var(--green); border-color: var(--green); }
.task-cb:checked::after {
  content: '✓'; position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  font-size: 9px; color: #000; font-weight: 900; line-height: 1;
}
.task-txt { font-size: 13px; color: var(--text); line-height: 1.5; flex: 1; }
.task-pages-badge {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  color: var(--text3); white-space: nowrap; flex-shrink: 0;
  align-self: center; padding-left: 8px;
}

.wk-note {
  margin: 0; padding: 7px 14px;
  border-top: 1px solid var(--sep);
  border-left: 2px solid var(--sep2);
  font-size: 12px; color: var(--text2); line-height: 1.55;
  background: var(--surface2);
}
.wk-note.warn { border-left-color: var(--amber); color: var(--amber-t); background: var(--amber-bg); }
.wk-note.ok   { border-left-color: var(--green); color: var(--green-t); background: var(--green-bg); }

/* ═══ VOLUMES ═══ */
#page-volumes { padding-bottom: 60px; }

.vol-cards { display: flex; flex-direction: column; }
.vol-card {
  border-left: 2px solid var(--sep2);
  border-bottom: 1px solid var(--sep);
  background: var(--surface);
  padding: 10px 14px;
}
.v1.vol-card { border-left-color: var(--orange); }
.v2.vol-card { border-left-color: var(--blue);   }
.v3.vol-card { border-left-color: var(--green);  }

.vc-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
.vc-lbl { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: .12em; text-transform: uppercase; font-weight: 600; }
.v1 .vc-lbl { color: var(--orange-t); }
.v2 .vc-lbl { color: var(--blue-t);   }
.v3 .vc-lbl { color: var(--green-t);  }
.vc-title { font-size: 15px; font-weight: 300; font-style: italic; color: var(--text2); }

.vc-bar-track { height: 5px; background: var(--sep2); border-radius: 2px; overflow: hidden; margin-bottom: 6px; }
.vc-bar-fill  { height: 100%; border-radius: 2px; transition: width .5s; }
.v1 .vc-bar-fill { background: var(--orange); }
.v2 .vc-bar-fill { background: var(--blue);   }
.v3 .vc-bar-fill { background: var(--green);  }

.vc-nums { display: flex; justify-content: space-between; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text3); }
.vc-nums .big { font-size: 14px; font-weight: 600; color: var(--text); }
.vc-marge { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text3); margin-top: 3px; }
.vc-marge span { color: var(--green-t); }

.vol-detail { border-bottom: 1px solid var(--sep); }
.vd-hdr {
  padding: 9px 14px; border-bottom: 1px solid var(--sep);
  display: flex; align-items: center; justify-content: space-between;
  background: var(--surface);
}
.vd-hdr-l { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; }
.vd-total { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text3); }

.sec-head {
  padding: 5px 14px;
  background: var(--surface2); border-bottom: 1px solid var(--sep);
  display: flex; justify-content: space-between; align-items: center;
  font-family: 'JetBrains Mono', monospace; font-size: 8px;
  color: var(--text3); letter-spacing: .08em; text-transform: uppercase;
}
.proj-row {
  padding: 6px 14px 6px 22px;
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--sep);
  font-size: 12px; color: var(--text2);
}
.proj-row:last-child { border-bottom: none; }
.proj-right { display: flex; gap: 8px; align-items: center; }
.proj-sem { font-family: 'JetBrains Mono', monospace; font-size: 8px; color: var(--text3); }
.proj-p   { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text); }

/* Scrollbar */
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-thumb { background: var(--sep2); }
</style>
</head>
