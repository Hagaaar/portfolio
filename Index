const GS_URL = 'https://script.google.com/macros/s/AKfycbzcEMTmWpc-x0XUpxu8KlY71xWQoVHO_SsR46sXo-m9VHEGlUqdvrAED_6H2sToCjQwkA/exec';
const LS_KEY = 'portfolio_v7_state';
let state = {};

function loadLocal() {
  try { const r = localStorage.getItem(LS_KEY); return r ? JSON.parse(r) : {}; }
  catch(e) { return {}; }
}
function saveLocal() {
  try { localStorage.setItem(LS_KEY, JSON.stringify(state)); } catch(e) {}
}

function setSyncDot(status) {
  const d = document.getElementById('syncDot');
  const l = document.getElementById('syncLabel');
  if (!d) return;
  const map = {
    ok:      { cls:'ok',      label:'Synchronisé' },
    syncing: { cls:'syncing', label:'Sync...' },
    error:   { cls:'offline', label:'Erreur' },
    offline: { cls:'offline', label:'Hors ligne' },
    local:   { cls:'',        label:'Local' },
  };
  const s = map[status] || map.local;
  d.className = 'sync-dot' + (s.cls ? ' ' + s.cls : '');
  if (l) l.textContent = s.label;
}

async function loadFromGS() {
  try {
    setSyncDot('syncing');
    const r = await fetch(GS_URL);
    const remote = await r.json();
    if (remote && Object.keys(remote).length > 0) {
      Object.keys(remote).forEach(k => { if (remote[k]) state[k] = true; });
      saveLocal();
    }
    setSyncDot('ok');
    return true;
  } catch(e) {
    setSyncDot('offline');
    return false;
  }
}

let saveTimer = null;
function scheduleRemoteSave() {
  clearTimeout(saveTimer);
  saveTimer = setTimeout(async () => {
    try {
      setSyncDot('syncing');
      await fetch(GS_URL, { method:'POST', mode:'no-cors', body:JSON.stringify(state) });
      setSyncDot('ok');
    } catch(e) { setSyncDot('offline'); }
  }, 800);
}

function isDone(id) { return !!state[id]; }
function setDone(id, v) {
  if (v) { state[id] = true; } else { delete state[id]; }
  saveLocal();
  scheduleRemoteSave();
}

