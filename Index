// HELPERS
// ══════════════════════════════════════════════════════════
function findCurrentWeek() {
  for (const e of PLANNING) {
    if (e.type === 'conges') continue;
    if (e.tasks.filter(t => isDone(t.id)).length < e.tasks.length) return e.id;
  }
  return null;
}

function taskCleanText(txt) { return txt.replace(/\s*\(\d+p\)/gi, '').trim(); }
function taskPageBadge(txt) {
  const m = txt.match(/\((\d+)p\)/i);
  return m ? '<span class="task-pages-badge">' + m[1] + ' p</span>' : '';
}

// ══════════════════════════════════════════════════════════
// RENDER PLANNING
// ══════════════════════════════════════════════════════════
function renderPlanning() {
  const currentId = findCurrentWeek();
  let h = '';
  PLANNING.forEach(e => {
    if (e.type === 'conges') {
      h += `<div class="conges-row">
        <span class="ci">✈️</span>
        <span class="cl">Congés</span>
        <span class="cd">${e.dates} · ${e.lbl}</span>
      </div>`;
      return;
    }
    const total = e.tasks.length;
    const done  = e.tasks.filter(t => isDone(t.id)).length;
    const pct   = total ? Math.round(done / total * 100) : 0;
    const isCur = e.id === currentId;
    const isAll = done === total;

    h += `<div class="wk ${e.type}${isAll ? ' done-all' : ''}${isCur ? ' current' : ''}" id="wk-${e.id}">
      <div class="wk-head" onclick="toggleWk('${e.id}')">
        <div class="wk-left">
          <div class="wk-badges">
            <span class="badge b-week">${e.week}</span>
            <span class="badge b-${e.type}">${e.type.toUpperCase()}</span>
            ${e.vol ? `<span class="badge ${e.vol}">${e.volLbl}</span>` : ''}
          </div>
          <div class="wk-title">${e.title}</div>
          <div class="wk-sub">${e.dates} · ${e.section}</div>
        </div>
        <div class="wk-right">
          ${e.pages ? `<span class="wk-pages">${e.pages}</span>` : ''}
          <div class="wk-prog-wrap">
            <div class="wk-prog-bar"><div class="wk-prog-fill" id="wpf-${e.id}" style="width:${pct}%"></div></div>
            <span class="wk-prog-pct" id="wpp-${e.id}">${pct}%</span>
          </div>
          <span class="chev">▾</span>
        </div>
      </div>
      <div class="wk-tasks" id="wkt-${e.id}">
        <div class="tasks-header" id="th-${e.id}">Tâches · ${done} / ${total}</div>
        ${e.tasks.map(t => `
          <div class="task${isDone(t.id) ? ' done' : ''}" id="tr-${t.id}"
            onclick="taskRowClick(event,'${t.id}','${e.id}')">
            <input type="checkbox" class="task-cb" id="cb-${t.id}" ${isDone(t.id) ? 'checked' : ''}>
            <span class="task-txt">${taskCleanText(t.txt)}</span>
            ${taskPageBadge(t.txt)}
          </div>`).join('')}
        ${e.note ? `<div class="wk-note${e.note.cls ? ' ' + e.note.cls : ''}">${e.note.txt}</div>` : ''}
      </div>
    </div>`;
  });
  document.getElementById('planCont').innerHTML = h;
}

// ══════════════════════════════════════════════════════════
// RENDER VOLUMES
// ══════════════════════════════════════════════════════════
function renderVolumes() {
  let h = '<div class="vol-cards">';
  VOLUMES.forEach(v => {
    const pct = Math.round(v.pages / v.limit * 100);
    h += `<div class="vol-card ${v.cls}">
      <div class="vc-top"><span class="vc-lbl">${v.lbl}</span><span class="vc-title">${v.title}</span></div>
      <div class="vc-bar-track"><div class="vc-bar-fill" style="width:${pct}%"></div></div>
      <div class="vc-nums"><span class="big">${v.pages}p</span><span>/ ${v.limit}p max</span></div>
      <div class="vc-marge">Marge : <span>+${v.marge}p</span></div>
    </div>`;
  });
  h += '</div>';

  VOLUMES.forEach(v => {
    const bc = v.cls === 'v1' ? 'b-vol1' : v.cls === 'v2' ? 'b-vol2' : 'b-vol3';
    h += `<div class="vol-detail">
      <div class="vd-hdr">
        <div class="vd-hdr-l"><span class="badge ${bc}">${v.lbl}</span>${v.title}</div>
        <span class="vd-total">${v.pages}p / ${v.limit}p</span>
      </div>`;
    v.sections.forEach(sec => {
      h += `<div class="sec-head"><span>${sec.name}</span><span>${sec.total}p · ${sec.projs.length} proj.</span></div>`;
      sec.projs.forEach(p => {
        h += `<div class="proj-row"><span>${p.n}</span><div class="proj-right"><span class="proj-sem">${p.s}</span><span class="proj-p">${p.p}p</span></div></div>`;
      });
    });
    h += '</div>';
  });

  document.getElementById('volCont').innerHTML = h;
}

// ══════════════════════════════════════════════════════════
// INTERACTIONS
// ══════════════════════════════════════════════════════════
function toggleWk(id) {
  document.getElementById('wk-' + id).classList.toggle('open');
}

function taskRowClick(e, tid, wid) {
  const cb = document.getElementById('cb-' + tid);
  cb.checked = !cb.checked;
  toggleTask(tid, wid, cb.checked);
}

function toggleTask(tid, wid, checked) {
  setDone(tid, checked);
  const row = document.getElementById('tr-' + tid);
  if (row) checked ? row.classList.add('done') : row.classList.remove('done');
  updateWeekProg(wid);
  updateGlobalProg();
}

function updateWeekProg(wid) {
  const entry = PLANNING.find(e => e.id === wid);
  if (!entry || !entry.tasks) return;
  const total = entry.tasks.length;
  const done  = entry.tasks.filter(t => isDone(t.id)).length;
  const pct   = Math.round(done / total * 100);
  const fill  = document.getElementById('wpf-' + wid);
  const lbl   = document.getElementById('wpp-' + wid);
  const th    = document.getElementById('th-'  + wid);
  const card  = document.getElementById('wk-'  + wid);
  if (fill) fill.style.width = pct + '%';
  if (lbl)  lbl.textContent  = pct + '%';
  if (th)   th.textContent   = `Tâches · ${done} / ${total}`;
  if (card) pct === 100 ? card.classList.add('done-all') : card.classList.remove('done-all');
}

function parseTaskPages(txt) {
  const m = txt.match(/\((\d+)p\)/);
  return m ? parseInt(m[1]) : 0;
}

function updateGlobalProg() {
  const all  = PLANNING.filter(e => e.tasks).flatMap(e => e.tasks);
  const done = all.filter(t => isDone(t.id)).length;
  const pct  = Math.round(done / all.length * 100);
  const fill = document.getElementById('gFill');
  const lbl  = document.getElementById('gLabel');
  if (fill) fill.style.width = pct + '%';
  if (lbl)  lbl.textContent  = `${done} / ${all.length}`;

  let totalPages = 0, donePages = 0;
  PLANNING.forEach(e => {
    if (!e.tasks) return;
    e.tasks.forEach(t => {
      const p = parseTaskPages(t.txt);
      totalPages += p;
      if (isDone(t.id)) donePages += p;
    });
  });
  const pPct  = totalPages ? Math.round(donePages / totalPages * 100) : 0;
  const pFill = document.getElementById('pFill');
  const pLbl  = document.getElementById('pLabel');
  if (pFill) pFill.style.width = pPct + '%';
  if (pLbl)  pLbl.textContent  = `${donePages} / ${totalPages}p`;
}

function switchTab(tab) {
  document.querySelectorAll('.tab-page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.hdr-tab').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + tab).classList.add('active');
  const btn = document.querySelector('.hdr-tab.tab-' + tab);
  if (btn) btn.classList.add('active');
}

// ══════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════
state = loadLocal();
setSyncDot('syncing');
renderPlanning();
renderVolumes();
updateGlobalProg();

// Auto-ouvre la semaine en cours et scrolle dessus
const _curId = findCurrentWeek();
if (_curId) {
  const _card = document.getElementById('wk-' + _curId);
  if (_card) {
    _card.classList.add('open');
    setTimeout(() => {
      const headerH = document.getElementById('header').offsetHeight;
      const top = _card.getBoundingClientRect().top + window.scrollY - headerH - 4;
      window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }, 80);
  }
}

loadFromGS().then(ok => {
  if (ok) {
    // Mémoriser les cartes ouvertes avant le re-render
    const openIds = [...document.querySelectorAll('.wk.open')].map(el => el.id.replace('wk-', ''));
    renderPlanning();
    updateGlobalProg();
    // Restaurer les cartes ouvertes (sans scroll)
    openIds.forEach(id => {
      const c = document.getElementById('wk-' + id);
      if (c) c.classList.add('open');
    });
    // La semaine en cours reste toujours ouverte
    const curId = findCurrentWeek();
    if (curId) {
      const c = document.getElementById('wk-' + curId);
      if (c) c.classList.add('open');
    }
  }
});
</script>
